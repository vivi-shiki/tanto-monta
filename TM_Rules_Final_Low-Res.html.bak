            ><span class="stl_82 stl_17 stl_21" style="word-spacing: -0.0678em"
              >one </span
            ><span class="stl_81 stl_17 stl_70" style="word-spacing: -0.0631em"
              >settlement can be established in each Ocean &nbsp;</span
            >
          </div>
          <div class="stl_01" style="left: 5.0833em; top: 8.7768em">
            <span class="stl_81 stl_17 stl_80" style="word-spacing: -0em"
              >Zone in a single impulse. &nbsp;</span
            >
          </div>
          <div class="stl_01" style="left: 4.4167em; top: 9.9769em">
            <span class="stl_81 stl_17 stl_18" style="word-spacing: 0.2419em"
              >• </span
            ><span class="stl_81 stl_17 stl_371">A</span
            ><span class="stl_81 stl_17 stl_67">s</span
            ><span class="stl_81 stl_17 stl_35">ettlement</span
            ><span class="stl_81 stl_17 stl_18" style="word-spacing: -0.062em"
              >&nbsp;</span
            ><span class="stl_81 stl_17 stl_35" style="word-spacing: -0.0631em"
              >may only be created if additional settlement coun- &nbsp;</span
            >
          </div>
          <div class="stl_01" style="left: 5.0833em; top: 10.927em">
            <span class="stl_81 stl_17 stl_178" style="word-spacing: -0.0621em"
