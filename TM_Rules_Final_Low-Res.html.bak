            ><span class="stl_81 stl_17 stl_402">V</span
            ><span class="stl_81 stl_17 stl_18">o</span
            ><span class="stl_81 stl_17 stl_30" style="word-spacing: 0em"
              >yage instead. &nbsp;</span
            >
          </div>
          <div class="stl_01" style="left: 3.75em; top: 6.5806em">
            <span class="stl_10 stl_08 stl_28">Limitations: &nbsp;</span>
          </div>
          <div class="stl_01" style="left: 4.4167em; top: 7.8268em">
            <span class="stl_81 stl_17 stl_18" style="word-spacing: 0.2419em"
              >• </span
            ><span class="stl_81 stl_17 stl_403">A</span
            ><span class="stl_81 stl_17 stl_62">m</span
            ><span class="stl_81 stl_17 stl_70">aximum</span
            ><span class="stl_81 stl_17 stl_18" style="word-spacing: -0.0639em"
              >&nbsp;</span
            ><span class="stl_81 stl_17 stl_21" style="word-spacing: -0.063em"
