            ><span class="stl_81 stl_17 stl_155">.</span
            ><span class="stl_81 stl_17 stl_186">A</span
            ><span class="stl_81 stl_17 stl_79" style="word-spacing: -0.0632em"
              >fter receiving his hand &nbsp;</span
            >
