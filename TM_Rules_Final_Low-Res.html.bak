            >
          </div>
          <div class="stl_01" style="left: 38.1408em; top: 10.2389em">
            <span class="stl_81 stl_17 stl_13" style="word-spacing: 0em"
              >1 naval resource &nbsp;</span
            >
          </div>
          <div class="stl_01" style="left: 37.9849em; top: 11.4541em">
            <span class="stl_81 stl_17 stl_13" style="word-spacing: -0em"
