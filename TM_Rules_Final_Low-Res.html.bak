            >
          </div>
          <div class="stl_01" style="left: 30.1339em; top: 9.0174em">
            <span class="stl_120 stl_17 stl_13">2-9 &nbsp;</span>
          </div>
          <div class="stl_01" style="left: 39.7202em; top: 7.8085em">
            <span class="stl_456 stl_17 stl_13">Result &nbsp;</span>
          </div>
          <div class="stl_01" style="left: 39.2911em; top: 9.0237em">
