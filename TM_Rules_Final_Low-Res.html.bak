            >
          </div>
          <div class="stl_01" style="left: 4.225em; top: 18.5192em">
            <span class="stl_10 stl_08 stl_36">Components &nbsp;</span>
          </div>
          <div class="stl_01" style="left: 4.225em; top: 19.7654em">
            <span class="stl_81 stl_17 stl_80" style="word-spacing: -0.0139em"
              >A complete game of </span
            ><span class="stl_82 stl_17 stl_83">T</span
            ><span class="stl_82 stl_17 stl_13">a</span
            ><span class="stl_82 stl_17 stl_80" style="word-spacing: -0.0001em"
              >nto Monta </span
            ><span class="stl_81 stl_17 stl_80">includes: &nbsp;</span>
          </div>
          <div class="stl_01" style="left: 4.8916em; top: 20.9656em">
            <span class="stl_81 stl_17 stl_18" style="word-spacing: 0.2419em"
              >• 1</span
            ><span class="stl_81 stl_17 stl_18" style="word-spacing: 0.01em"
              >&nbsp;</span
            ><span class="stl_81 stl_17 stl_13" style="word-spacing: 0.0001em"
