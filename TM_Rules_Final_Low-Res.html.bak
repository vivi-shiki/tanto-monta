            >
          </div>
          <div class="stl_01" style="left: 3.75em; top: 8.7901em">
            <span class="stl_91 stl_17 stl_13" style="word-spacing: 0.0001em"
              >Immediate Effects: </span
            ><span class="stl_78 stl_17 stl_80" style="word-spacing: -0.0002em"
